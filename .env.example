# GitHub Models — used for text generation and embeddings
# Get token at https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# OpenAI API key — required ONLY for image/vision processing (GPT-4o Vision)
# GitHub Models endpoint does not support base64 image inputs.
# Without this, images are ingested with a metadata-only placeholder.
OPENAI_API_KEY=your_openai_api_key_here

# Chainlit auth secret — required when multi-tenancy / login is enabled
# Generate with: chainlit create-secret
# Or: python -c 'import secrets; print("CHAINLIT_AUTH_SECRET=" + secrets.token_hex(32))'
CHAINLIT_AUTH_SECRET=your_secret_here

# Optional overrides
OPENAI_EMBEDDING_MODEL=text-embedding-3-large
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_VISION_MODEL=gpt-4o
CHROMA_PERSIST_DIR=./data/chroma_db
UPLOAD_DIR=./data/uploads
